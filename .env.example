# ===========================================
# SacredVote — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (required)
# Example: postgresql://user:password@localhost:5432/sacredvote
DATABASE_URL=

# Password for the /admin CMS panel (recommended)
# If not set, falls back to SESSION_SECRET, then "admin"
ADMIN_PASSWORD=

# Fallback secret used when ADMIN_PASSWORD is not set (recommended)
# Also available for future session-signing use
SESSION_SECRET=

# Server port (optional, default: 5000)
# On Replit the PORT is set automatically; locally you can override it
PORT=5000

# Node environment (optional, default: development)
# Set to "production" to enable HSTS, serve static files from dist/, etc.
NODE_ENV=development
# Recovery password for admin lockout reset (required for lockout recovery)
# If not set, lockout recovery is disabled — you must restart the service to clear a lockout
RECOVERY_PASSWORD=
